{
  "name": "claude-forge",
  "version": "1.0.5",
  "private": true,
  "description": "Forge workspace containing the CLI client and the future self-developed agent.",
  "workspaces": [
    "cli",
    "agent"
  ],
  "scripts": {
    "dev": "npm --workspace @claude-forge/cli run dev",
    "build": "npm --workspace @claude-forge/cli run build",
    "preview": "npm --workspace @claude-forge/cli run preview",
    "build:win": "npm --workspace @claude-forge/cli run build:win",
    "typecheck": "npm --workspace @claude-forge/cli run typecheck",
    "cli:dev": "npm --workspace @claude-forge/cli run dev",
    "cli:build": "npm --workspace @claude-forge/cli run build",
    "cli:build:win": "npm --workspace @claude-forge/cli run build:win",
    "cli:typecheck": "npm --workspace @claude-forge/cli run typecheck",
    "agent:typecheck": "npm --workspace @claude-forge/agent run typecheck"
  }
}
